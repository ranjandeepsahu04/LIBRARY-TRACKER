<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="950.0" style="-fx-background-color: linear-gradient(to bottom right, #34495e, #3498db);" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.manage.lms.UserLoginSignupController">
    <VBox alignment="CENTER" spacing="20.0">
        <VBox alignment="CENTER" prefWidth="400.0" maxWidth="450.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30 40 30 40;" spacing="15.0">
            <effect>
                <DropShadow color="#00000066" radius="15.0" offsetY="10.0"/>
            </effect>
            
            <Label text="Create Account" textFill="#2c3e50">
                <font>
                    <Font name="System Bold" size="32.0"/>
                </font>
                <VBox.margin>
                    <Insets bottom="5.0"/>
                </VBox.margin>
            </Label>
            
            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label text="Username" textFill="#7f8c8d">
                    <font><Font name="System Bold" size="13.0"/></font>
                </Label>
                <TextField fx:id="signupUsername" prefHeight="40.0" promptText="Choose a username" style="-fx-background-radius: 8; -fx-border-color: #bdc3c7; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-font-size: 13px;"/>
            </VBox>
            
            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label text="Age" textFill="#7f8c8d">
                    <font><Font name="System Bold" size="13.0"/></font>
                </Label>
                <TextField fx:id="signupAge" prefHeight="40.0" promptText="Enter your age" style="-fx-background-radius: 8; -fx-border-color: #bdc3c7; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-font-size: 13px;"/>
            </VBox>
            
            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label text="Email Address" textFill="#7f8c8d">
                    <font><Font name="System Bold" size="13.0"/></font>
                </Label>
                <TextField fx:id="signupMail" prefHeight="40.0" promptText="Enter your email address" style="-fx-background-radius: 8; -fx-border-color: #bdc3c7; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-font-size: 13px;"/>
            </VBox>
            
            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label text="Password" textFill="#7f8c8d">
                    <font><Font name="System Bold" size="13.0"/></font>
                </Label>
                <PasswordField fx:id="signupPassword" prefHeight="40.0" promptText="Create a secure password" style="-fx-background-radius: 8; -fx-border-color: #bdc3c7; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-font-size: 13px;"/>
            </VBox>
            
            <Label fx:id="signupError" textFill="#e74c3c" wrapText="true">
                <font><Font size="12.0"/></font>
            </Label>
            
            <Button fx:id="signupButton" onAction="#signUp" prefHeight="45.0" prefWidth="1000.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Sign Up">
                <font><Font name="System Bold" size="16.0"/></font>
                <VBox.margin>
                    <Insets top="5.0"/>
                </VBox.margin>
            </Button>
            
            <HBox alignment="CENTER" spacing="5.0">
                <padding><Insets top="5.0"/></padding>
                <Label text="Already have an account?" textFill="#7f8c8d"/>
                <Label onMouseClicked="#goToSignin" text="Sign In" textFill="#2ecc71" style="-fx-cursor: hand;">
                    <font><Font name="System Bold" size="13.0"/></font>
                </Label>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
